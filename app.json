{
  "expo": {
    "name": "LUMINA",
    "slug": "LUMINA",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "lumina",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.u.lumina"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
